---
import Layout from "../layouts/Layout.astro";

const solutions = [
  {
    title: "AI-Assisted Workflow Automation for Campaign Page Generation",
    desc: "The system is designed with a clear separation between AI processing, automation, and human validation.",
    status: "In Progress",
    link: "/solution_pagegenerator",
  },
  {
    title: "Wild Reports System",
    desc: "Reporting system for structured data collection, analysis, and internal visibility.",
    status: "In Progress",
    link: "/solution_stwstw",
  },
  {
    title: "Website with CloudCannon CMS",
    desc: "CMS-driven website architecture focused on scalability and content management efficiency.",
    status: "Case Study",
    link: "/solution_kat",
  },
];
---

<Layout title="RAFAEL HIRASHIKI's Implemented Features and other metrics">
  <div
    class="relative z-50 col-start-2 col-span-10 max-sm:col-start-3 max-sm:col-span-9"
  >
    <h2 class="italic text-2xl clr-brand-orange pb-8">Solutions</h2>

    <ul class="grid md:grid-cols-2 gap-8">
      {
        solutions.map((project) => (
          <li>
            <a
              href={project.link}
              class="group block border border-neutral-200 rounded-2xl p-6 hover:shadow-xl transition-all duration-300 bg-white h-full"
            >
              {/* Status */}
              <span class="text-xs uppercase tracking-wide text-neutral-400">
                {project.status}
              </span>

              {/* Title */}
              <h3 class="text-xl font-semibold text-neutral-900 mt-2 group-hover:text-orange-500 transition">
                {project.title}
              </h3>

              {/* Description */}
              <p class="text-sm text-neutral-600 mt-3 leading-relaxed">
                {project.desc}
              </p>

              {/* Bottom accent */}
              <div class="mt-6 flex items-center justify-between">
                <div class="h-[2px] w-10 bg-neutral-300 group-hover:bg-orange-500 transition-all" />

                <span class="text-sm text-neutral-400 group-hover:text-orange-500 transition">
                  →
                </span>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</Layout>
